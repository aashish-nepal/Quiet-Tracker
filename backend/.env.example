PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/price_tracker

# Internal security
CRON_SECRET=replace-with-random-string
JWT_SECRET=replace-with-long-random-string
ENABLE_DEMO_AUTH=false
JWT_EXPIRES_IN=7d
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=40

# Screenshot storage
# Options: file (local disk, dev only) | inline (base64, no deps) | s3 (production recommended)
SCREENSHOT_STORAGE_DIR=./storage/screenshots
SCREENSHOT_STORAGE_MODE=file

# S3 screenshot storage (only required when SCREENSHOT_STORAGE_MODE=s3)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
# AWS credentials (or use instance role / env injection in cloud)
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx

EXCHANGE_RATES_API_URL=https://open.er-api.com/v6/latest/USD

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_TRIAL_DAYS=7
STRIPE_GRACE_DAYS=3
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# SendGrid
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=alerts@quiettracker.app

# Amazon Product Advertising API
AMAZON_PARTNER_TAG=yourtag-20
AMAZON_ACCESS_KEY=xxx
AMAZON_SECRET_KEY=xxx
AMAZON_MARKETPLACE=www.amazon.com

# Etsy (optional key, scraping fallback exists)
ETSY_API_KEY=optional

